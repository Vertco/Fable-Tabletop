; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Fable Tabletop"
config/version="0.1.alpha"
run/main_scene="uid://b4cb0o2tdrbk1"
config/auto_accept_quit=false
config/features=PackedStringArray("4.6", "Forward Plus")
run/max_fps=60
boot_splash/image="uid://b5q42lqsc61ve"
config/icon="uid://r2axqenpq8r2"
config/macos_native_icon="res://media/branding/icon.icns"
config/windows_native_icon="res://media/branding/icon.ico"
boot_splash/minimum_display_time=1500

[autoload]

App="*uid://cnccuygscfr7n"
Prefs="*uid://5mpn3dbv5rjd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/size/initial_position_type=4
window/stretch/aspect="ignore"
window/vsync/vsync_mode=2

[file_customization]

folder_colors={
"res://media/": "red",
"res://media/shaders/": "red",
"res://nodes/": "orange",
"res://resources/": "yellow",
"res://scenes/": "green",
"res://singletons/": "gray"
}

